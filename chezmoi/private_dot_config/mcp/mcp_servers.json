{
  "mcpServers": {
    "codegraph": {
      "command": "npx",
      "args": ["--yes", "@colbymchenry/codegraph", "serve", "--mcp"]
    },
    "context-mode": {
      "command": "npx",
      "args": ["--yes", "context-mode"]
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": ["--yes", "@playwright/mcp"]
    }
  }
}
