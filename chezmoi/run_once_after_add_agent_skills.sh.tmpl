#!/usr/bin/env bash
set -euo pipefail

if npx -v claude >/dev/null; then
  agents=(
    claude-code
    gemini-cli
    opencode
  )
  agent_args=("${agents[@]/#/--agent }")

  skills=(
    vercel-labs/skills
    obra/superpowers
    JuliusBrussee/caveman
    anthropics/skills
    mattpocock/skills
  )
  for entry in "${skills[@]}"; do
    npx --yes skills add "${entry}" --global "${agent_args[@]}" --skill "*" --yes
  done
fi
