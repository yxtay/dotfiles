{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "fallbackModel": ["bedrock.claude-sonnet-4-5"],
  "modelOverrides": {
    "claude-haiku-4-5": "bedrock.claude-haiku-4-5",
    "claude-sonnet-4-5": "bedrock.claude-sonnet-4-5",
    "claude-sonnet-4-6": "bedrock.claude-sonnet-4-6",
    "claude-sonnet-5": "bedrock.claude-sonnet-5",
    "claude-opus-4-8": "bedrock.claude-opus-4-8"
  },
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "bedrock.claude-haiku-4-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "bedrock.claude-opus-4-8",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "bedrock.claude-sonnet-4-6"
  },
  "autoCompactEnabled": true,
  "awaySummaryEnabled": true,
  "fileCheckpointingEnabled": true,
  "outputStyle": "Proactive",
  "preferredNotifChannel": "terminal_bell",
  "permissions": {
    "defaultMode": "auto",
    "disableBypassPermissionsMode": "disable",
    "additionalDirectories": ["~/.memsearch", "~/wiki"],
    "ask": [
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/.mcp.json)",
      "Edit(**/.claude/settings.json)",
      "Edit(**/.claude/settings.local.json)",
      "Edit(~/.aws/**)",
      "Edit(~/.azure/**)",
      "Edit(~/.config/gh/**)",
      "Edit(~/.docker/**)",
      "Edit(~/.gcp/**)",
      "Edit(~/.git-credentials)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.kube/**)",
      "Edit(~/.ssh/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/**)",
      "Read(~/.gcp/**)",
      "Read(~/.git-credentials)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(~/.ssh/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": ["docker *"],
    "filesystem": {
      "allowWrite": [
        "~/.cache",
        "~/.cargo/registry",
        "~/.gradle",
        "~/.local/lib",
        "~/.local/share/uv",
        "~/.m2",
        "~/.npm",
        "~/.yarn",
        "~/Library/Caches",
        "~/Library/Python",
        "~/Library/pnpm",
        "~/go/pkg",
        "~/wiki"
      ]
    }
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "worktree": {
    "baseRef": "fresh"
  }
}
