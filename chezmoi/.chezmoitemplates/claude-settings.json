{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "fallbackModel": ["bedrock.claude-sonnet-4-5"],
  "modelOverrides": {
    "claude-haiku-4-5": "bedrock.claude-haiku-4-5",
    "claude-sonnet-4-5": "bedrock.claude-sonnet-4-5",
    "claude-sonnet-4-6": "bedrock.claude-sonnet-4-6[1m]",
    "claude-opus-4-8": "bedrock.claude-opus-4-8[1m]"
  },
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "bedrock.claude-haiku-4-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "bedrock.claude-opus-4-8[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "bedrock.claude-sonnet-4-6[1m]"
  },
  "autoCompactEnabled": true,
  "awaySummaryEnabled": true,
  "fileCheckpointingEnabled": true,
  "outputStyle": "Proactive",
  "preferredNotifChannel": "terminal_bell",
  "permissions": {
    "defaultMode": "auto",
    "disableBypassPermissionsMode": "disable",
    "ask": [
      "Edit(/.claude/settings.json)",
      "Edit(/.claude/settings.local.json)",
      "Edit(~/.claude/settings.json)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ],
    "deny": [
      "Edit(**/credentials*)",
      "Edit(**/secrets*)",
      "Edit(~/.aws/**)",
      "Edit(~/.azure/**)",
      "Edit(~/.docker/**)",
      "Edit(~/.gcp/**)",
      "Edit(~/.git-credentials)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.kube/**)",
      "Edit(~/.netrc)",
      "Edit(~/.npmrc)",
      "Edit(~/.pypirc)",
      "Edit(~/.ssh/**)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.docker/**)",
      "Read(~/.gcp/**)",
      "Read(~/.git-credentials)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.ssh/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "enableWeakerNetworkIsolation": true,
    "credentials": {
      "files": [
        { "path": "~/.aws", "mode": "deny" },
        { "path": "~/.azure", "mode": "deny" },
        { "path": "~/.docker", "mode": "deny" },
        { "path": "~/.gcp", "mode": "deny" },
        { "path": "~/.git-credentials", "mode": "deny" },
        { "path": "~/.gnupg", "mode": "deny" },
        { "path": "~/.kube", "mode": "deny" },
        { "path": "~/.netrc", "mode": "deny" },
        { "path": "~/.npmrc", "mode": "deny" },
        { "path": "~/.pypirc", "mode": "deny" },
        { "path": "~/.ssh", "mode": "deny" }
      ]
    },
    "excludedCommands": ["docker"],
    "filesystem": {
      "allowWrite": [
        "~/.cache",
        "~/.cargo",
        "~/.gradle",
        "~/.local",
        "~/.m2",
        "~/.npm",
        "~/.yarn",
        "~/Library/Caches",
        "~/Library/Python",
        "~/Library/pnpm",
        "~/go/pkg"
      ]
    }
  },
  "statusLine": {
    "type": "command",
    "command": "npx --yes context-mode statusline"
  },
  "worktree": {
    "baseRef": "fresh"
  }
}
