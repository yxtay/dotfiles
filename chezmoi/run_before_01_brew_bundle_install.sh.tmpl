{{ if and (eq .chezmoi.os "darwin") (not .is_ephemeral) -}}
#!/usr/bin/env bash
set -euo pipefail

{{- if eq .chezmoi.arch "arm64" }}
HOMEBREW_PREFIX="/opt/homebrew"
{{- else }}
HOMEBREW_PREFIX="/usr/local"
{{- end }}
eval "$("${HOMEBREW_PREFIX}/bin/brew" shellenv)"

brew bundle install --cleanup --zap --file=/dev/stdin <<EOF

###
# cli utilities
###

# text
brew "bat"
brew "jq"
brew "ripgrep"
brew "sd"
brew "yq"

# shell
brew "atuin"
brew "btop"
# brew "timescam/homebrew-tap/pay-respects"
brew "procs"
brew "tlrc"

# files
brew "dtrx"
brew "duf"
brew "dust"
brew "eza"
brew "fd"
brew "fzf"
brew "zoxide"

# security
brew "gnupg"

# data transfer
brew "httpie"
brew "rclone"
brew "rsync"
brew "unison"

# git
brew "git"
brew "git-delta"
brew "git-extras"
brew "git-lfs"
brew "gh"
brew "glab"

###
# misc
###

# terminals & editors
brew "helix"
brew "tmux"

# dev
brew "ansible"
brew "bitwarden-cli"
brew "oven-sh/bun/bun"
brew "deno"
brew "direnv"
brew "go"
brew "libomp"
brew "mise"
brew "node"
brew "ollama"
brew "pnpm"
brew "rustup"
brew "hashicorp/tap/terraform"
brew "terragrunt"
brew "yarn"

# python
uv "uv"
uv "pre-commit"
uv "ruff"
uv "ty"

# work
brew "awscli"
brew "azure-cli"
brew "databricks/tap/databricks"

# container
brew "docker"
brew "docker-buildx"
brew "docker-compose"
brew "docker-credential-helper"
brew "kubectl"

brew "colima"

###
# GNU
###
# https://github.com/shinokada/macgnu
# https://github.com/pkill37/linuxify

# GNU programs non-existing in macOS
brew "autoconf"
brew "tree"
brew "watch"
brew "wdiff"
brew "wget"

# GNU programs whose BSD counterpart is installed in macOS
brew "coreutils"
brew "binutils"
brew "diffutils"
brew "ed"
brew "findutils"
brew "gawk"
brew "gnu-indent"
brew "gnu-sed"
brew "gnu-tar"
brew "gnu-which"
brew "grep"
brew "gzip"
brew "screen"

# GNU programs existing in macOS which are outdated
brew "bash"
brew "bison"
brew "emacs"
brew "gpatch"
brew "less"
brew "m4"
brew "make"
brew "nano"

# BSD programs existing in macOS which are outdated
brew "flex"

##
# casks
##

# mac
cask "rectangle"

# web
cask "adguard"
cask "brave-browser"
cask "firefox"

# communication
cask "microsoft-auto-update" # for microsoft-teams
cask "microsoft-teams"
cask "slack"
cask "zoom"

# dev
cask "claude-code"
cask "github"
cask "visual-studio-code"
cask "wezterm"

# entertainment
cask "spotify"

# work
cask "cloudflare-warp"
cask "intune-company-portal"
cask "libreoffice"

EOF
{{ end -}}
