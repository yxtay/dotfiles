[".local/bin/mcp-cli"]
  type = "file"
{{- if (eq .chezmoi.arch "amd64") }}
  url = "{{ gitHubLatestReleaseAssetURL "philschmid/mcp-cli" (printf "mcp-cli-%s-%s" .chezmoi.os "x64") }}"
{{- else }}
  url = "{{ gitHubLatestReleaseAssetURL "philschmid/mcp-cli" (printf "mcp-cli-%s-%s" .chezmoi.os .chezmoi.arch) }}"
{{- end }}
  executable = true
  refreshPeriod = "168h"

{{- if .is_ephemeral }}
[".local/bin/fzf"]
  type = "archive-file"
  url = "{{ gitHubLatestReleaseAssetURL "junegunn/fzf" (printf "fzf-*-%s_%s.tar.gz" .chezmoi.os .chezmoi.arch) }}"
  path = "fzf"
  executable = true
  refreshPeriod = "168h"

[".local/bin/rtk"]
  type = "archive-file"
{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.arch "amd64") }}
  url = "{{ gitHubLatestReleaseAssetURL "rtk-ai/rtk" (printf "rtk-%s-%s.tar.gz" .arch "unknown-linux-musl") }}"
{{- else }}
  url = "{{ gitHubLatestReleaseAssetURL "rtk-ai/rtk" (printf "rtk-%s-%s.tar.gz" .arch .os) }}"
{{- end }}
  path = "rtk"
  executable = true
  refreshPeriod = "168h"
{{- end }}
