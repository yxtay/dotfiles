[".config/git/alias"]
  type = "file"
  url = "https://github.com/GitAlias/gitalias/raw/main/gitalias.txt"
  refreshPeriod = "168h"

[".config/git/ignore"]
  type = "file"
{{- if eq .chezmoi.os "darwin" }}
  url = "https://github.com/github/gitignore/raw/main/Global/macOS.gitignore"
{{- else if eq .chezmoi.os "windows" }}
  url = "https://github.com/github/gitignore/raw/main/Global/Windows.gitignore"
{{- else }}
  url = "https://github.com/github/gitignore/raw/main/Global/Linux.gitignore"
{{- end }}
  refreshPeriod = "168h"

{{- if .is_ephemeral }}
[".local/bin/bat"]
  type = "archive-file"
  url = "{{ gitHubLatestReleaseAssetURL "sharkdp/bat" (printf "bat-*-%s-%s.tar.gz" .arch .os) }}"
  path = "bat"
  stripComponents = 1
  executable = true
  refreshPeriod = "168h"

[".local/bin/delta"]
  type = "archive-file"
  url = "{{ gitHubLatestReleaseAssetURL "dandavison/delta" (printf "delta-*-%s-%s.tar.gz" .arch .os) }}"
  path = "delta"
  stripComponents = 1
  executable = true
  refreshPeriod = "168h"

