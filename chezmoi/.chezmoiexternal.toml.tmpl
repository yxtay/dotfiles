[".config/git/alias"]
  type = "file"
  url = "https://github.com/GitAlias/gitalias/raw/main/gitalias.txt"
  refreshPeriod = "168h"

[".config/git/ignore"]
  type = "file"
{{- if eq .chezmoi.os "darwin" }}
  url = "https://github.com/github/gitignore/raw/main/Global/macOS.gitignore"
{{- else if eq .chezmoi.os "windows" }}
  url = "https://github.com/github/gitignore/raw/main/Global/Windows.gitignore"
{{- else }}
  url = "https://github.com/github/gitignore/raw/main/Global/Linux.gitignore"
{{- end }}
  refreshPeriod = "168h"

{{- if .is_ephemeral }}
[".local/bin/fzf"]
  type = "archive-file"
  url = "{{ gitHubLatestReleaseAssetURL "junegunn/fzf" (printf "fzf-*-%s_%s.tar.gz" .chezmoi.os .chezmoi.arch) }}"
  path = "fzf"
  executable = true
  refreshPeriod = "168h"

{{- if eq .chezmoi.os "linux" }}
[".local/bin/opencode"]
  type = "archive-file"
  url = "{{ gitHubLatestReleaseAssetURL "anomalyco/opencode" (printf "opencode-%s-%s.tar.gz" .chezmoi.os .chezmoi.arch) }}"
  path = "opencode"
  executable = true
  refreshPeriod = "168h"
{{- end }}
{{- end }}
