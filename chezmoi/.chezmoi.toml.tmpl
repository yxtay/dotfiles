{{- $is_ephemeral := eq "true" (env "CI") (env "CODESPACES") (env "REMOTE_CONTAINERS") }}
{{- $is_ephemeral = or $is_ephemeral (eq .chezmoi.username "debian" "ubuntu" "user") }}
{{- $is_interactive := stdinIsATTY }}

{{- $arch := "x86_64" }}
{{- if eq .chezmoi.arch "arm64" }}
{{- $arch = "aarch64" }}
{{- else if eq .chezmoi.arch "386" }}
{{- $arch = "i686" }}
{{- end }}

{{- $os := "unknown-linux-gnu" }}
{{- if eq .chezmoi.os "darwin" }}
{{- $os = "apple-darwin" }}
{{- else if eq .chezmoi.os "windows" }}
{{- $os = "pc-windows-msvc" }}
{{- end }}

{{- if lookPath "bat" }}
pager = "bat"
{{- end }}
progress = {{ $is_interactive }}

[data]
git_user = "yxtay"
git_email = "5795122+yxtay@users.noreply.github.com"
arch = "{{ $arch }}"
os = "{{ $os }}"
is_ephemeral = {{ $is_ephemeral }}
is_interactive = {{ $is_interactive }}

{{- if not $is_ephemeral }}
git_email_work = "tay.yuxuan@gt.tech.gov.sg"
{{- end }}

[diff]
{{- if lookPath "delta" }}
command = "delta"
pager = "delta"
{{- end }}

[edit]
apply = true

[git]
autoCommit = true
autoPush = true

[github]
refreshPeriod = "1h"

[env]
PATH = "/${HOME}/.local/bin:/home/linuxbrew/.linuxbrew/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

[scriptEnv]
PATH = "/${HOME}/.local/bin:/home/linuxbrew/.linuxbrew/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
{{- if not $is_interactive }}
DEBIAN_FRONTEND = "noninteractive"
NONINTERACTIVE = "true"
{{- end }}
