{
  "description": "OKF wiki maintenance — distill memsearch journals into ~/wiki at session end and before context compaction",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/okf-wiki-maintenance.sh",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/okf-wiki-maintenance.sh",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ]
  }
}
